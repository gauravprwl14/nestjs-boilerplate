# =============================================================================
# Application
# =============================================================================
NODE_ENV=test
APP_NAME=enterprise-twitter
APP_PORT=3001
APP_HOST=0.0.0.0
API_PREFIX=api
API_VERSION=1
LOG_LEVEL=warn

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://gauravporwal@localhost:5432/enterprise_twitter_test?schema=public

# =============================================================================
# OpenTelemetry (off in tests)
# =============================================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=enterprise-twitter-test

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# Shutdown
# =============================================================================
SHUTDOWN_TIMEOUT_MS=3000

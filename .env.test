# =============================================================================
# Application
# =============================================================================
NODE_ENV=test
APP_NAME=ai-native-nestjs-backend
APP_PORT=3001
APP_HOST=0.0.0.0
API_PREFIX=api
API_VERSION=v1
LOG_LEVEL=warn

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/todo_test?schema=public

# =============================================================================
# Redis (Cache + BullMQ)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# =============================================================================
# Authentication
# =============================================================================
JWT_ACCESS_SECRET=test-access-secret-must-be-32-chars-long!
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=test-refresh-secret-must-be-32-chars-long!
JWT_REFRESH_EXPIRATION=7d
API_KEY_ENCRYPTION_SECRET=test-api-key-secret-32-chars-long!!
BCRYPT_ROUNDS=4

# =============================================================================
# OpenTelemetry
# =============================================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ai-native-nestjs-backend-test
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# =============================================================================
# Rate Limiting
# =============================================================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=1000

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# Shutdown
# =============================================================================
SHUTDOWN_TIMEOUT_MS=10000

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TweetVisibility {
  COMPANY
  DEPARTMENTS
  DEPARTMENTS_AND_SUBDEPARTMENTS
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// A tenant. Every other row is scoped under exactly one Company.
model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  users       User[]
  departments Department[]
  tweets      Tweet[]

  @@map("companies")
}

/// A user belongs to one Company and optionally many Departments.
/// Mock-auth uses the bare user.id passed via x-user-id header.
model User {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  email     String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments UserDepartment[]
  tweets      Tweet[]

  @@index([companyId])
  @@map("users")
}

/// Department tree, adjacency-list style (parentId self-FK).
/// The composite FK on (parentId, companyId) is the DB-level guarantee that
/// a department's parent MUST live in the same company — preventing cross-tenant
/// hierarchy poisoning even if a service layer bug slips past validation.
model Department {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  parentId  String?  @map("parent_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent  Department? @relation("DepartmentHierarchy", fields: [parentId, companyId], references: [id, companyId], onDelete: SetNull)
  children Department[] @relation("DepartmentHierarchy")

  members UserDepartment[]
  tweets  TweetDepartment[]

  // Composite unique lets other tables form a same-company composite FK into this row.
  @@unique([id, companyId])
  @@index([companyId])
  @@index([parentId])
  @@map("departments")
}

/// Join table: which departments does a user belong to?
/// companyId is denormalized so the tenant-scope Prisma extension can filter uniformly.
model UserDepartment {
  userId       String   @map("user_id")
  departmentId String   @map("department_id")
  companyId    String   @map("company_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([companyId])
  @@index([departmentId])
  @@map("user_departments")
}

/// A short message.
model Tweet {
  id         String          @id @default(uuid())
  companyId  String          @map("company_id")
  authorId   String          @map("author_id")
  content    String          @db.VarChar(280)
  visibility TweetVisibility
  createdAt  DateTime        @default(now()) @map("created_at")

  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author  User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  targets TweetDepartment[]

  // Composite unique lets tweet_departments form a same-company composite FK into this row.
  @@unique([id, companyId])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([authorId])
  @@map("tweets")
}

/// Which departments is a department-scoped tweet targeted at?
/// Empty for COMPANY visibility. Composite FKs to both tweets and departments
/// enforce that every targeted department shares the tweet's company.
model TweetDepartment {
  tweetId      String @map("tweet_id")
  departmentId String @map("department_id")
  companyId    String @map("company_id")

  tweet      Tweet      @relation(fields: [tweetId, companyId], references: [id, companyId], onDelete: Cascade)
  department Department @relation(fields: [departmentId, companyId], references: [id, companyId], onDelete: Cascade)

  @@id([tweetId, departmentId])
  @@index([companyId])
  @@index([departmentId])
  @@map("tweet_departments")
}

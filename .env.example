# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
APP_NAME=enterprise-twitter
APP_PORT=3000
APP_HOST=0.0.0.0
API_PREFIX=api
API_VERSION=1
LOG_LEVEL=info

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_twitter_dev?schema=public

# =============================================================================
# OpenTelemetry (disabled for the assignment — enable in infra environments)
# =============================================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=enterprise-twitter
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# Shutdown
# =============================================================================
SHUTDOWN_TIMEOUT_MS=10000

# =============================================================================
# docker-compose interpolation only (not read by the app)
# Copy this file to `.env` at the repo root — docker-compose auto-loads it
# for ${VAR} substitution in docker-compose.yml and the observability configs.
# =============================================================================

# Postgres credentials (used by the postgres service + app DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_twitter_dev

# Intra-network URLs consumed by observability config files
TEMPO_URL=http://tempo:3200
LOKI_URL=http://loki:3100
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_REMOTE_WRITE_URL=http://prometheus:9090/api/v1/write
LOKI_OTLP_ENDPOINT=http://loki:3100/otlp
TEMPO_OTLP_GRPC_ENDPOINT=tempo:4317
